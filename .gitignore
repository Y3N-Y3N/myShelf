# =========================
# ENV FILES (NEVER COMMIT)
# =========================
.env
.env.*
!.env.example

# =========================
# OS / IDE
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# LOGS
# =========================
*.log
logs/

# =========================
# =========================
# FRONTEND (Next.js)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# Next.js misc
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# package managers (if ever used)
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/

# =========================
# BACKEND (FastAPI / Python)
# =========================
backend/venv/
backend/__pycache__/
backend/**/*.pyc
backend/.pytest_cache/
backend/.mypy_cache/
backend/.coverage/

# SQLAlchemy / Alembic
backend/alembic/versions/*.pyc

# =========================
# DEBUG FILES
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# SECURITY / KEYS
# =========================
*.pem